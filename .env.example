# ============================================================================
# EspritConnect — environment template.
# Copy to ".env" (which is gitignored) and fill in real values:
#     cp .env.example .env
# Sensible defaults exist for a fresh clone, so `docker compose up --build`
# works out of the box; override everything marked "CHANGE IN PROD".
# ============================================================================

# ── Object storage (MinIO / S3) ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_prod              # CHANGE IN PROD
# Public endpoint the browser uses to fetch uploaded files (avatars, CVs…).
# Leave as localhost for local dev. In a deployment, set it to your public URL.
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
# Optional: master key to enable SSE-S3 encryption at rest for the
# verification bucket. Generate: echo "ec-key:$(openssl rand -base64 32)"
MINIO_KMS_SECRET_KEY=

# ── Python verification service ─────────────────────────────────────────────
# Shared secret between Spring and the FastAPI verification service.
VERIFICATION_SHARED_SECRET=replace_me_with_a_64_char_random_string   # CHANGE IN PROD

# ── Local LLM (Ollama) ──────────────────────────────────────────────────────
# Pulled automatically at startup — no model file is committed to the repo.
OLLAMA_MODEL=qwen2.5:0.5b
# Optional: reuse models already pulled on the host (skip re-download).
# OLLAMA_DATA=/home/youruser/.ollama

# ── SMTP (transactional email) ──────────────────────────────────────────────
# Leave MAIL_USERNAME blank to disable real sending (codes are logged to the
# backend console instead). For Gmail use a 16-char App Password.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=EspritConnect
MAIL_STARTTLS=true
MAIL_SSL=false

# ── App / web ───────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:4200
# Allowed browser origins for the API. "*" works behind any tunnel/host for a
# demo; set explicit origins in production, e.g. https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=*

# ── Optional: persistent database directory (for encryption-at-rest setups) ──
# PGDATA_DIR=/mnt/pgdata-enc

# ── Optional: stable public URL via a Cloudflare named tunnel ───────────────
# CLOUDFLARE_TUNNEL_TOKEN=

# ── NOTE ────────────────────────────────────────────────────────────────────
# The database password (DB_PASSWORD) and JWT secret (JWT_SECRET) are currently
# set directly in docker-compose.yml with dev defaults. For a real deployment,
# change them there (or wire them to these vars) before exposing the app.
